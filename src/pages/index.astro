---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allEvents = await getCollection('events');
const upcomingEvents = allEvents
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = allEvents
  .filter(e => e.data.status === 'past')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base
  title="InsanaSonido — Techno Events in Spain"
  description="InsanaSonido: curated underground electronic music events in Spain. Techno, Tech-House, Trance and more. Presented by Sonido Sessions & Project Insana."
  canonicalPath="/"
>
  <!-- Header -->
  <header>
    <div class="container">
      <nav>
        <div class="logo">Insana<span>Sonido</span></div>
        <div class="nav-links" id="navLinks">
          <a href="#events">Events</a>
          <a href="/blog/">Blog</a>
          <a href="https://www.instagram.com/projectinsana" target="_blank" rel="noopener noreferrer" class="text-magenta">Instagram</a>
        </div>
        <button class="mobile-menu-btn" id="menuBtn" aria-expanded="false" aria-controls="navLinks" aria-label="Toggle navigation">☰</button>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Underground <span class="text-magenta">Sounds</span></h1>
      <p>CURATED ELECTRONIC EVENTS BY SONIDO SESSIONS // PROJECT INSANA</p>
      <a href="#events" class="btn btn-primary">See Events</a>
    </div>
  </section>

  <!-- Marquee -->
  <div class="marquee-container">
    <div class="marquee-content">
      <div class="marquee-block">
        <span class="marquee-item">TECHNO &nbsp;•&nbsp; TECH-HOUSE &nbsp;•&nbsp; TECH-TRANCE &nbsp;•&nbsp; HARDGROOVE &nbsp;•&nbsp; MAKINA &nbsp;•&nbsp; INSANASONIDO &nbsp;•&nbsp; SONIDO SESSIONS &nbsp;•&nbsp; PROJECT INSANA &nbsp;•&nbsp;</span>
      </div>
    </div>
  </div>

  <!-- About -->
  <section class="section-padding">
    <div class="container text-center">
      <h2 class="section-title">Who We <span class="text-magenta">Are</span></h2>
      <p class="section-subtitle" style="max-width: 680px; margin: 0 auto;">
        InsanaSonido is the fusion of Sonido Sessions and Project Insana — two collectives united by a love of underground electronic music.<br />We bring raw, curated rave experiences to Spain's South Coast.
      </p>
    </div>
  </section>

  <!-- Events -->
  <section id="events" class="section-padding bg-dark">
    <div class="container">
      {upcomingEvents.length > 0 && (
        <>
          <h2 class="section-title">Upcoming <span class="text-magenta">Events</span></h2>
          <div class="events-grid">
            {upcomingEvents.map(event => {
              const dateStr = event.data.date.toLocaleDateString('en-GB', {
                day: 'numeric', month: 'long', year: 'numeric'
              });
              return (
                <a href={`/${event.data.slug}`} class="event-card">
                  <img src={event.data.coverImage} alt={event.data.title} loading="lazy" />
                  <div class="event-card-body">
                    <div class="event-card-title">{event.data.title}</div>
                    <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                    <div class="event-card-genres">
                      {event.data.genres.slice(0, 3).map(g => <span class="genre-tag">{g}</span>)}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      )}

      {pastEvents.length > 0 && (
        <>
          <h2 class="section-title" style="margin-top: 4rem;">Past <span class="text-magenta">Events</span></h2>
          <div class="events-grid">
            {pastEvents.map(event => {
              const dateStr = event.data.date.toLocaleDateString('en-GB', {
                day: 'numeric', month: 'long', year: 'numeric'
              });
              return (
                <a href={`/${event.data.slug}`} class="event-card event-card--past">
                  <img src={event.data.coverImage} alt={event.data.title} loading="lazy" />
                  <div class="event-card-body">
                    <div class="event-card-title">{event.data.title}</div>
                    <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      )}

      {upcomingEvents.length === 0 && pastEvents.length === 0 && (
        <p class="section-subtitle text-center">Events coming soon. Follow us on Instagram for updates.</p>
      )}
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container footer-content">
      <div class="logo">Insana<span>Sonido</span></div>
      <div class="socials">
        <a href="https://www.instagram.com/projectinsana" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <img src="/images/instagram-white-icon.svg" alt="Instagram" />
        </a>
        <a href="https://www.facebook.com/events/s/follow-the-rabbit/740952528841627/#" class="social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <img src="/images/facebook-app-round-white-icon.svg" alt="Facebook" />
        </a>
      </div>
      <div class="footer-bottom">
        <div class="presenters">Sonido Sessions &amp; Project Insana.</div>
        <div class="copyright">&copy; {new Date().getFullYear()} InsanaSonido. All rights reserved.</div>
      </div>
    </div>
  </footer>
</Base>

<style>
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .event-card {
    display: block;
    border: 1px solid rgba(217, 0, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition);
    position: relative;
    max-width: 280px;
    margin-inline: auto;
  }

  .event-card:hover {
    border-color: var(--color-magenta);
  }

  .event-card img {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .event-card:hover img {
    transform: scale(1.03);
  }

  .event-card-body {
    padding: 1.25rem;
  }

  .event-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .event-card-meta {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.75rem;
  }

  .event-card--past img {
    filter: grayscale(0.6);
  }

  .event-card-genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
