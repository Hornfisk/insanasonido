---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allEvents = await getCollection('events');
const sortedEvents = allEvents.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base
  title="Events — InsanoSonido"
  description="All InsanoSonido events. Underground electronic music in Spain — Techno, Tech-House, Tech-Trance."
  canonicalPath="/events/"
>
  <header>
    <div class="container">
      <nav>
        <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insano<span>Sonido</span></a></div>
        <div class="nav-links" id="navLinks">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
        </div>
        <button class="mobile-menu-btn" id="menuBtn" aria-expanded="false" aria-controls="navLinks" aria-label="Toggle navigation">☰</button>
      </nav>
    </div>
  </header>

  <section class="section-padding" style="padding-top: 8rem;">
    <div class="container">
      <h1 class="section-title">All <span class="text-magenta">Events</span></h1>
      <div class="events-grid">
        {sortedEvents.map(event => {
          const dateStr = event.data.date.toLocaleDateString('en-GB', {
            day: 'numeric', month: 'long', year: 'numeric'
          });
          return (
            <a href={`/${event.data.slug}`} class={`event-card${event.data.status === 'past' ? ' event-card--past' : ''}`}>
              <img src={event.data.coverImage} alt={event.data.title} loading="lazy" />
              <div class="event-card-body">
                <div class="event-card-status">{event.data.status === 'upcoming' ? '● Upcoming' : 'Past'}</div>
                <div class="event-card-title">{event.data.title}</div>
                <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                <div class="event-card-genres">
                  {event.data.genres.slice(0, 3).map(g => <span class="genre-tag">{g}</span>)}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <footer>
    <div class="container footer-content">
      <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insano<span>Sonido</span></a></div>
      <div class="footer-bottom">
        <div class="copyright">&copy; {new Date().getFullYear()} InsanoSonido. All rights reserved.</div>
      </div>
    </div>
  </footer>
</Base>

<style>
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .event-card {
    display: block;
    border: 1px solid rgba(217, 0, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition);
  }

  .event-card:hover {
    border-color: var(--color-magenta);
  }

  .event-card img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .event-card--past img {
    filter: grayscale(0.6);
  }

  .event-card-body {
    padding: 1.25rem;
  }

  .event-card-status {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-magenta);
    margin-bottom: 0.4rem;
  }

  .event-card--past .event-card-status {
    color: rgba(255,255,255,0.4);
  }

  .event-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .event-card-meta {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.75rem;
  }

  .event-card-genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
