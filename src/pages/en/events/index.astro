---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const dateLocale = locale === 'es' ? 'es-ES' : 'en-GB';
const canonicalBase = locale === 'en' ? '/en' : '';
const homeUrl = getRelativeLocaleUrl(locale, '/');

const allEvents = await getCollection('events', e => e.data.lang === locale);
const sortedEvents = allEvents.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base
  title="Events — InsanaSonido"
  description="All InsanaSonido events. Underground electronic music in Spain — Techno, Tech-House, Tech-Trance."
  canonicalPath={`${canonicalBase}/events/`}
  locale={locale}
>
  <Header variant="blog" logoHref={homeUrl} />

  <section class="section-padding" style="padding-top: 8rem;">
    <div class="container">
      <h1 class="section-title" set:html={t('allEvents.pageH1')} />
      <div class="events-grid">
        {sortedEvents.map(event => {
          const dateStr = event.data.date.toLocaleDateString(dateLocale, {
            day: 'numeric', month: 'long', year: 'numeric'
          });
          const eventUrl = getRelativeLocaleUrl(locale, `/${event.data.urlSlug}/`);
          return (
            <a href={eventUrl} class={`event-card${event.data.status === 'past' ? ' event-card--past' : ''}`}>
              <img src={event.data.coverImage} alt={event.data.title} loading="lazy" />
              <div class="event-card-body">
                <div class="event-card-status">
                  {event.data.status === 'upcoming' ? t('allEvents.upcoming') : t('allEvents.past')}
                </div>
                <div class="event-card-title">{event.data.title}</div>
                <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                <div class="event-card-genres">
                  {event.data.genres.slice(0, 3).map(g => <span class="genre-tag">{g}</span>)}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer logoHref={homeUrl} />
</Base>

<style>
  .events-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem; margin-top: 2rem; }
  .event-card { display: block; border: 1px solid rgba(217,0,255,0.2); border-radius: 4px; overflow: hidden; text-decoration: none; color: inherit; transition: border-color var(--transition); width: 220px; }
  .event-card:hover { border-color: var(--color-magenta); }
  .event-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .event-card:hover img { transform: scale(1.03); }
  .event-card--past img { filter: grayscale(0.6); }
  .event-card-body { padding: 1.25rem; }
  .event-card-status { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-magenta); margin-bottom: 0.4rem; }
  .event-card--past .event-card-status { color: rgba(255,255,255,0.4); }
  .event-card-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.4rem; }
  .event-card-meta { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-bottom: 0.75rem; }
  .event-card-genres { display: flex; flex-wrap: wrap; gap: 0.4rem; }
</style>
