---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const events = await getCollection('events', e => e.data.lang === 'en');
  return events.map(event => ({
    params: { slug: event.data.urlSlug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { data } = event;

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const homeUrl = getRelativeLocaleUrl(locale, '/');
const eventsUrl = getRelativeLocaleUrl(locale, '/events/');
const dateLocale = locale === 'es' ? 'es-ES' : 'en-GB';
const canonicalBase = locale === 'en' ? '/en' : '';

const dateFormatted = new Date(data.date).toLocaleDateString(dateLocale, {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const eventSchema = {
  name: data.title,
  description: event.body?.trim() || data.title,
  url: data.urlSlug,
  image: data.coverImage,
  startDate: `${data.date.toISOString().split('T')[0]}T${data.startTime}:00`,
  genres: data.genres,
  venue: data.venue,
  organizers: data.organizers,
  performers: data.lineup.filter(a => a.booked).map(a => ({ name: a.name, socialUrl: a.socialUrl })),
  ticketUrl: data.ticketUrl,
  ticketTiers: data.ticketTiers.map(tier => ({
    name: tier.name,
    price: parseFloat(tier.price.replace(/[^0-9.]/g, '')),
  })),
};

const pageTitle = `${data.title} | Rave Night · ${data.venue.split(',')[1]?.trim() ?? data.venue} · ${dateFormatted}`;
const minPrice = data.ticketTiers.map(tier => parseFloat(tier.price.replace(/[^0-9.]/g, ''))).sort((a, b) => a - b)[0];
const pageDescription = `${data.title} rave at ${data.venue} – ${dateFormatted}. ${data.genres.slice(0, 3).join(', ')}. Tickets from €${minPrice}. ${t('event.presentedBy')} ${data.organizers.map(o => o.name).join(' & ')}.`;

const sortedLineup = [...data.lineup].sort((a, b) => Number(b.booked) - Number(a.booked));

const [logoMain, ...logoRest] = data.title.split(' ');
const logoAccent = logoRest.join(' ');

const presenterLine = `${t('event.presentedBy')} ${data.organizers.map(o => o.name).join(' & ')}.`;
const copyrightName = `${data.title} Event`;

const breadcrumbs = [
  { name: locale === 'es' ? 'Inicio' : 'Home', url: homeUrl },
  { name: locale === 'es' ? 'Eventos' : 'Events', url: eventsUrl },
  { name: data.title, url: `${canonicalBase}/${data.urlSlug}/` },
];
---
<Base
  title={pageTitle}
  description={pageDescription}
  ogImage={data.coverImage}
  canonicalPath={`${canonicalBase}/${data.urlSlug}/`}
  eventSchema={eventSchema}
  breadcrumbs={breadcrumbs}
  locale={locale}
>
  <Header variant="event" logoMain={logoMain} logoAccent={logoAccent} logoHref={homeUrl} />

  <!-- Hero -->
  <section class="hero hero--event">
    <img src={data.logoImage ?? data.coverImage} alt={`${data.title} Logo`} class="rabbit-icon" fetchpriority="high" />
    <div class="container hero-content">
      <h1>{t('event.heroH1')} <span class="text-magenta">{t('event.heroH1Accent')}</span></h1>
      <p>PRESENTED BY {data.organizers.map(o => o.name).join(' // ').toUpperCase()}</p>
      <a href="#tickets" class="btn btn-primary">{t('event.heroCta')}</a>
    </div>
  </section>

  <!-- Marquee -->
  <div class="marquee-container">
    <div class="marquee-content">
      <div class="marquee-block">
        <span class="marquee-item">TECHNO (HYPNOTIC, HARDGROOVE, MAKINA) &nbsp;•&nbsp; TECH-TRANCE &nbsp;•&nbsp; TECH-HOUSE &nbsp;•&nbsp; BY SONIDO SESSIONS &amp; PROJECT INSANA &nbsp;•&nbsp;</span>
      </div>
    </div>
  </div>

  <!-- Lineup -->
  <section id="lineup" class="section-padding">
    <div class="container">
      <div class="text-center">
        <p class="lineup-label">{t('nav.lineup')}</p>
      </div>
      <div class="lineup-viewport">
        <div class="lineup-grid" id="lineupGrid">
          {sortedLineup.map(artist => (
            <div class="artist-card">
              {artist.booked ? (
                <a href={artist.socialUrl} target="_blank" rel="noopener noreferrer">
                  <img src={artist.image} alt={`${artist.name} DJ`} class="artist-img" />
                </a>
              ) : (
                <img src={artist.image} alt="" class="artist-img" />
              )}
              <div class="artist-name">{artist.booked ? artist.name.toUpperCase() : 'TBA'}</div>
              <div class="artist-genre">
                {artist.genres.map(g => <span class="genre-tag">{g}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Info & Tickets -->
  <section id="info" class="section-padding bg-dark">
    <div class="container">
      <div class="info-layout">
        <div class="info-box">
          <h2 class="info-section-title">{t('event.missionH2')} <span class="text-magenta">{t('event.missionH2Accent')}</span></h2>
          <div class="info-item">
            <span class="info-label">{t('event.date')}</span>
            <span class="info-value">{dateFormatted}</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t('event.time')}</span>
            <span class="info-value">{data.startTime} - {data.endTime}</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t('event.location')}</span>
            <span class="info-value">
              <a href="https://www.instagram.com/mangos_nightclub/" target="_blank" rel="noopener noreferrer" class="location-link">
                {data.venue.split(',')[0]}<br />{data.venue.split(',')[1]?.trim()}
              </a>
            </span>
          </div>
          <div class="info-item">
            <span class="info-label">{t('event.ageRestriction')}</span>
            <span class="info-value">{t('event.ageValue')}</span>
          </div>
        </div>
        <div id="tickets" class="info-box info-box--alt">
          <h2 class="info-section-title">{t('event.accessH2')} <span class="text-magenta">{t('event.accessH2Accent')}</span></h2>
          {data.ticketTiers.map(tier => (
            <div class="ticket-tier">
              <div>
                <div class="ticket-name">{tier.name}</div>
              </div>
              <div class="price">{tier.price}</div>
            </div>
          ))}
          <a href={data.ticketUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn--full">
            {data.ticketButtonLabel ?? t('event.buyTickets')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="section-padding">
    <div class="container">
      <h2 class="section-title text-center">{t('event.galleryH2')} <span class="text-magenta">{t('event.galleryH2Accent')}</span></h2>
      <div class="gallery-viewport">
        <div class="gallery-grid" id="galleryGrid">
          {data.gallery.map((src, i) => (
            <div class="gallery-item">
              <img src={src} alt={`${data.title} at ${data.venue} – photo ${i + 1}`} loading="lazy" />
            </div>
          ))}
          {data.gallery.map(src => (
            <div class="gallery-item" aria-hidden="true">
              <img src={src} alt="" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer
    logoMain={logoMain}
    logoAccent={logoAccent}
    logoHref={homeUrl}
    showSocials
    presenterLine={presenterLine}
    copyrightName={copyrightName}
  />

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-prev" aria-label="Previous photo">&#8249;</button>
    <button class="lightbox-next" aria-label="Next photo">&#8250;</button>
    <div class="lightbox-img-wrap">
      <img class="lightbox-img" src="" alt="" />
    </div>
  </div>
</Base>
