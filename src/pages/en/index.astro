---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const dateLocale = locale === 'es' ? 'es-ES' : 'en-GB';
const canonicalBase = locale === 'en' ? '/en' : '';

const allEvents = await getCollection('events', e => e.data.lang === locale);
const upcomingEvents = allEvents
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = allEvents
  .filter(e => e.data.status === 'past')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = locale === 'es'
  ? 'InsanaSonido — Eventos Techno en España'
  : 'InsanaSonido — Techno Events in Spain';
const pageDesc = locale === 'es'
  ? 'InsanaSonido: eventos de música electrónica underground en España. Techno, Tech-House, Trance y más. Presentados por Sonido Sessions & Project Insana.'
  : 'InsanaSonido: curated underground electronic music events in Spain. Techno, Tech-House, Trance and more. Presented by Sonido Sessions & Project Insana.';
---
<Base
  title={pageTitle}
  description={pageDesc}
  canonicalPath={`${canonicalBase}/`}
  locale={locale}
>
  <Header variant="home" />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <h1>{t('home.heroH1')} <span class="text-magenta">{t('home.heroH1Accent')}</span></h1>
      <p>{t('home.heroSub')}</p>
      <a href="#events" class="btn btn-primary">{t('home.heroCta')}</a>
    </div>
  </section>

  <!-- Marquee -->
  <div class="marquee-container">
    <div class="marquee-content">
      <div class="marquee-block">
        <span class="marquee-item">TECHNO &nbsp;•&nbsp; TECH-HOUSE &nbsp;•&nbsp; TECH-TRANCE &nbsp;•&nbsp; HARDGROOVE &nbsp;•&nbsp; MAKINA &nbsp;•&nbsp; INSANASONIDO &nbsp;•&nbsp; SONIDO SESSIONS &nbsp;•&nbsp; PROJECT INSANA &nbsp;•&nbsp;</span>
      </div>
    </div>
  </div>

  <!-- About -->
  <section class="section-padding">
    <div class="container text-center">
      <h2 class="section-title">{t('home.aboutH2')} <span class="text-magenta">{t('home.aboutH2Accent')}</span></h2>
      <p class="section-subtitle" style="max-width: 680px; margin: 0 auto;">
        {t('home.aboutBody')}
      </p>
    </div>
  </section>

  <!-- Events -->
  <section id="events" class="section-padding bg-dark">
    <div class="container">
      {upcomingEvents.length > 0 && (
        <>
          <h2 class="section-title">{t('home.upcomingH2')} <span class="text-magenta">{t('home.upcomingH2Accent')}</span></h2>
          <div class="events-grid">
            {upcomingEvents.map(event => {
              const dateStr = event.data.date.toLocaleDateString(dateLocale, {
                day: 'numeric', month: 'long', year: 'numeric'
              });
              const eventUrl = getRelativeLocaleUrl(locale, `/${event.data.urlSlug}/`);
              return (
                <a href={eventUrl} class="event-card">
                  <Image src={event.data.coverImage} alt={event.data.title} loading="lazy" width={440} height={660} />
                  <div class="event-card-body">
                    <div class="event-card-title">{event.data.title}</div>
                    <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                    <div class="event-card-genres">
                      {event.data.genres.slice(0, 3).map(g => <span class="genre-tag">{g}</span>)}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      )}

      {pastEvents.length > 0 && (
        <>
          <h2 class="section-title" style="margin-top: 4rem;">{t('home.pastH2')} <span class="text-magenta">{t('home.pastH2Accent')}</span></h2>
          <div class="events-grid">
            {pastEvents.map(event => {
              const dateStr = event.data.date.toLocaleDateString(dateLocale, {
                day: 'numeric', month: 'long', year: 'numeric'
              });
              const eventUrl = getRelativeLocaleUrl(locale, `/${event.data.urlSlug}/`);
              return (
                <a href={eventUrl} class="event-card event-card--past">
                  <Image src={event.data.coverImage} alt={event.data.title} loading="lazy" width={440} height={660} />
                  <div class="event-card-body">
                    <div class="event-card-title">{event.data.title}</div>
                    <div class="event-card-meta">{dateStr} · {event.data.venue}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      )}

      {upcomingEvents.length === 0 && pastEvents.length === 0 && (
        <p class="section-subtitle text-center">{t('home.noEvents')}</p>
      )}
    </div>
  </section>

  <Footer
    showSocials
    presenterLine="Sonido Sessions & Project Insana."
  />
</Base>

<style>
  .events-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .event-card {
    display: block;
    border: 1px solid rgba(217, 0, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition);
    position: relative;
    width: 220px;
  }

  .event-card:hover { border-color: var(--color-magenta); }
  .event-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .event-card:hover img { transform: scale(1.03); }
  .event-card-body { padding: 1.25rem; }
  .event-card-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.4rem; }
  .event-card-meta { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-bottom: 0.75rem; }
  .event-card--past img { filter: grayscale(0.6); }
  .event-card-genres { display: flex; flex-wrap: wrap; gap: 0.4rem; }
</style>
