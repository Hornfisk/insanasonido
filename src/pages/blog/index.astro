---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---
<Base
  title="Blog — InsanaSonido"
  description="News, recaps, and announcements from InsanaSonido."
  canonicalPath="/blog/"
>
  <header>
    <div class="container">
      <nav>
        <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insana<span>Sonido</span></a></div>
        <div class="nav-links" id="navLinks">
          <a href="/">Home</a>
          <a href="/events/">Events</a>
        </div>
        <button class="mobile-menu-btn" id="menuBtn" aria-expanded="false" aria-controls="navLinks" aria-label="Toggle navigation">☰</button>
      </nav>
    </div>
  </header>

  <section class="section-padding" style="padding-top: 8rem;">
    <div class="container">
      <h1 class="section-title">The <span class="text-magenta">Journal</span></h1>

      {sortedPosts.length === 0 ? (
        <p class="section-subtitle" style="margin-top: 2rem;">No posts yet. Check back after the next event.</p>
      ) : (
        <div class="posts-list">
          {sortedPosts.map(post => {
            const dateStr = post.data.publishDate.toLocaleDateString('en-GB', {
              day: 'numeric', month: 'long', year: 'numeric'
            });
            return (
              <a href={`/blog/${post.data.slug}`} class="post-card">
                <img src={post.data.coverImage} alt={post.data.title} loading="lazy" class="post-card-img" />
                <div class="post-card-body">
                  <div class="post-card-date">{dateStr}</div>
                  <div class="post-card-title">{post.data.title}</div>
                  <p class="post-card-excerpt">{post.data.excerpt}</p>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <footer>
    <div class="container footer-content">
      <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insana<span>Sonido</span></a></div>
      <div class="footer-bottom">
        <div class="copyright">&copy; {new Date().getFullYear()} InsanaSonido. All rights reserved.</div>
      </div>
    </div>
  </footer>
</Base>

<style>
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  .post-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.5rem;
    border: 1px solid rgba(217, 0, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition);
  }

  .post-card:hover {
    border-color: var(--color-magenta);
  }

  .post-card-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .post-card-body {
    padding: 1.5rem 1.5rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-card-date {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .post-card-excerpt {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .post-card {
      grid-template-columns: 1fr;
    }
    .post-card-img {
      aspect-ratio: 16/9;
    }
    .post-card-body {
      padding: 1.25rem;
    }
  }
</style>
