---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.publishDate.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---
<Base
  title={`${post.data.title} — InsanoSonido`}
  description={post.data.excerpt}
  ogImage={post.data.coverImage}
  canonicalPath={`/blog/${post.data.slug}`}
>
  <header>
    <div class="container">
      <nav>
        <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insano<span>Sonido</span></a></div>
        <div class="nav-links" id="navLinks">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
        </div>
        <button class="mobile-menu-btn" id="menuBtn" aria-expanded="false" aria-controls="navLinks" aria-label="Toggle navigation">☰</button>
      </nav>
    </div>
  </header>

  <article class="section-padding post-article" style="padding-top: 8rem;">
    <div class="container post-container">
      <img src={post.data.coverImage} alt={post.data.title} class="post-cover" />
      <div class="post-meta">{dateStr}</div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-excerpt">{post.data.excerpt}</p>
      <div class="post-body">
        <Content />
      </div>
    </div>
  </article>

  <footer>
    <div class="container footer-content">
      <div class="logo"><a href="/" style="text-decoration:none;color:inherit;">Insano<span>Sonido</span></a></div>
      <div class="footer-bottom">
        <div class="copyright">&copy; {new Date().getFullYear()} InsanoSonido. All rights reserved.</div>
      </div>
    </div>
  </footer>
</Base>

<style>
  .post-container {
    max-width: 740px;
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .post-meta {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-excerpt {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 2rem;
    border-left: 2px solid var(--color-magenta);
    padding-left: 1rem;
  }

  .post-body {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.85);
  }

  .post-body h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
  }

  .post-body p {
    margin-bottom: 1.25rem;
  }

  .post-body a {
    color: var(--color-magenta);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
