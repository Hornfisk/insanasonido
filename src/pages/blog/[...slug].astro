---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const posts = allPosts.filter(p => p.data.lang === 'es');
  return posts.map(post => ({
    params: { slug: post.data.urlSlug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const locale = Astro.currentLocale ?? 'es';
const dateLocale = locale === 'es' ? 'es-ES' : 'en-GB';
const canonicalBase = locale === 'en' ? '/en' : '';
const homeUrl = getRelativeLocaleUrl(locale, '/');
const blogUrl = getRelativeLocaleUrl(locale, '/blog/');

const dateStr = post.data.publishDate.toLocaleDateString(dateLocale, {
  day: 'numeric', month: 'long', year: 'numeric'
});

const breadcrumbs = [
  { name: locale === 'es' ? 'Inicio' : 'Home', url: homeUrl },
  { name: 'Blog', url: blogUrl },
  { name: post.data.title, url: `${canonicalBase}/blog/${post.data.urlSlug}/` },
];

const blogSchema = {
  title: post.data.title,
  description: post.data.excerpt,
  publishDate: post.data.publishDate.toISOString(),
  image: post.data.coverImage,
  url: `${canonicalBase}/blog/${post.data.urlSlug}/`,
};
---
<Base
  title={`${post.data.title} — InsanaSonido`}
  description={post.data.excerpt}
  ogImage={post.data.coverImage}
  canonicalPath={`${canonicalBase}/blog/${post.data.urlSlug}/`}
  blogSchema={blogSchema}
  breadcrumbs={breadcrumbs}
  locale={locale}
>
  <Header variant="blog-post" logoHref={homeUrl} />

  <article class="section-padding post-article" style="padding-top: 8rem;">
    <div class="container post-container">
      <img src={post.data.coverImage} alt={post.data.title} class="post-cover" />
      <div class="post-meta">{dateStr}</div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-excerpt">{post.data.excerpt}</p>
      <div class="post-body">
        <Content />
      </div>
    </div>
  </article>

  <Footer logoHref={homeUrl} />
</Base>

<style>
  .post-container {
    max-width: 740px;
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .post-meta {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-excerpt {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 2rem;
    border-left: 2px solid var(--color-magenta);
    padding-left: 1rem;
  }

  .post-body {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.85);
  }
</style>
