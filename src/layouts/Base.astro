---
import '../styles/global.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import type { ImageMetadata } from 'astro';

interface EventSchema {
  name: string;
  description: string;
  url: string;
  image: string;
  startDate: string;
  genres: string[];
  venue: string;
  organizers: { name: string; url: string }[];
  performers: { name: string; socialUrl: string }[];
  ticketUrl: string;
  ticketTiers: { name: string; price: number }[];
}

interface BlogSchema {
  title: string;
  description: string;
  publishDate: string;
  image: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string | ImageMetadata;
  canonicalPath: string;
  eventSchema?: EventSchema;
  blogSchema?: BlogSchema;
  breadcrumbs?: { name: string; url: string }[];
  locale?: string;
  lcpImageSrc?: string;
}

const {
  title,
  description,
  ogImage = '/images/events/rabbit/follow-the-rabbit-event.webp',
  canonicalPath,
  eventSchema,
  blogSchema,
  breadcrumbs,
  locale = 'es',
  lcpImageSrc,
} = Astro.props;

const siteUrl = 'https://insanasonido.es';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageRaw = typeof ogImage === 'string' ? ogImage : ogImage?.src ?? '/images/events/rabbit/follow-the-rabbit-event.webp';
const ogImageUrl = ogImageRaw.startsWith('http') ? ogImageRaw : `${siteUrl}${ogImageRaw}`;
const ogLocale = locale === 'en' ? 'en_GB' : 'es_ES';

// Hreflang URLs: derive both language versions from canonicalPath
const esPath = locale === 'en' ? (canonicalPath.replace(/^\/en/, '') || '/') : canonicalPath;
const enPath = locale === 'en' ? canonicalPath : `/en${canonicalPath}`;
const esCanonicalUrl = `${siteUrl}${esPath}`;
const enCanonicalUrl = `${siteUrl}${enPath}`;

const musicEventLD = eventSchema ? {
  '@context': 'https://schema.org',
  '@type': 'MusicEvent',
  name: eventSchema.name,
  description: eventSchema.description,
  url: canonicalUrl,
  image: `${siteUrl}${eventSchema.image}`,
  startDate: eventSchema.startDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  genre: eventSchema.genres,
  typicalAgeRange: '18-',
  location: {
    '@type': 'Place',
    name: eventSchema.venue.split(',')[0].trim(),
    address: {
      '@type': 'PostalAddress',
      addressLocality: eventSchema.venue.split(',')[1]?.trim() ?? eventSchema.venue,
      addressRegion: 'Andalusia',
      addressCountry: 'ES',
    },
  },
  organizer: eventSchema.organizers.map(o => ({ '@type': 'Organization', name: o.name, url: o.url })),
  performer: eventSchema.performers.map(p => ({ '@type': 'MusicGroup', name: p.name, url: p.socialUrl })),
  offers: eventSchema.ticketTiers.map(tier => ({
    '@type': 'Offer',
    name: tier.name,
    price: tier.price,
    priceCurrency: 'EUR',
    url: eventSchema.ticketUrl,
    availability: 'https://schema.org/InStock',
  })),
} : null;

function safeJsonLd(obj: unknown): string {
  return JSON.stringify(obj)
    .replace(/<\//g, '<\\/')
    .replace(/<!--/g, '<\\!--')
    .replace(/]]>/g, ']]\\>');
}

const websiteLD = !eventSchema ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'InsanaSonido',
  url: siteUrl,
} : null;

const organizationLD = !eventSchema ? {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'InsanaSonido',
  url: siteUrl,
  description: 'Underground electronic music events on the Costa del Sol. Techno, Tech-House, Makina and more. Presented by Sonido Sessions & Project Insana.',
  sameAs: [
    'https://www.instagram.com/projectinsana',
    'https://www.facebook.com/events/s/follow-the-rabbit/740952528841627/',
  ],
} : null;

const blogPostLD = blogSchema ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: blogSchema.title,
  description: blogSchema.description,
  image: blogSchema.image.startsWith('http') ? blogSchema.image : `${siteUrl}${blogSchema.image}`,
  datePublished: blogSchema.publishDate,
  url: blogSchema.url.startsWith('http') ? blogSchema.url : `${siteUrl}${blogSchema.url}`,
  publisher: {
    '@type': 'Organization',
    name: 'InsanaSonido',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': blogSchema.url.startsWith('http') ? blogSchema.url : `${siteUrl}${blogSchema.url}`,
  },
} : null;

const breadcrumbLD = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.url.startsWith('http') ? crumb.url : `${siteUrl}${crumb.url}`,
  })),
} : null;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={esCanonicalUrl} />
    <link rel="alternate" hreflang="en" href={enCanonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={esCanonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="InsanaSonido" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {lcpImageSrc && <link rel="preload" as="image" href={lcpImageSrc} type="image/webp" />}

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-M8XLQ99J8T" crossorigin="anonymous"></script>
    <script is:inline src="/js/analytics.js" defer></script>



    {musicEventLD && (
      <script type="application/ld+json" set:html={safeJsonLd(musicEventLD)} />
    )}
    {websiteLD && (
      <script type="application/ld+json" set:html={safeJsonLd(websiteLD)} />
    )}
    {organizationLD && (
      <script type="application/ld+json" set:html={safeJsonLd(organizationLD)} />
    )}
    {blogPostLD && (
      <script type="application/ld+json" set:html={safeJsonLd(blogPostLD)} />
    )}
    {breadcrumbLD && (
      <script type="application/ld+json" set:html={safeJsonLd(breadcrumbLD)} />
    )}
  </head>
  <body>
    <!-- Background Elements -->
    <div class="bg-gradient"></div>
    <div class="grid-overlay"></div>
    <div id="crt" aria-hidden="true"></div>

    {breadcrumbs && breadcrumbs.length > 1 && (
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <div class="container">
          <ol>
            {breadcrumbs.map((crumb, i) => (
              <li>
                {i < breadcrumbs.length - 1 ? (
                  <a href={crumb.url}>{crumb.name}</a>
                ) : (
                  <span aria-current="page">{crumb.name}</span>
                )}
              </li>
            ))}
          </ol>
        </div>
      </nav>
    )}

    <slot />

    <script src="/js/main.js" defer></script>
  </body>
</html>
