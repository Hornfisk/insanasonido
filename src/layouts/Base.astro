---
import '../styles/global.css';

interface EventSchema {
  name: string;
  description: string;
  url: string;
  image: string;
  startDate: string;
  genres: string[];
  venue: string;
  organizers: { name: string; url: string }[];
  performers: { name: string; socialUrl: string }[];
  ticketUrl: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath: string;
  eventSchema?: EventSchema;
}

const {
  title,
  description,
  ogImage = '/images/events/rabbit/follow-the-rabbit-event.webp',
  canonicalPath,
  eventSchema,
} = Astro.props;

const siteUrl = 'https://insanasonido.es';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const musicEventLD = eventSchema ? {
  '@context': 'https://schema.org',
  '@type': 'MusicEvent',
  name: eventSchema.name,
  description: eventSchema.description,
  url: `${siteUrl}/${eventSchema.url}`,
  image: `${siteUrl}${eventSchema.image}`,
  startDate: eventSchema.startDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  genre: eventSchema.genres,
  typicalAgeRange: '18-',
  location: {
    '@type': 'Place',
    name: eventSchema.venue.split(',')[0].trim(),
    address: {
      '@type': 'PostalAddress',
      addressLocality: eventSchema.venue.split(',')[1]?.trim() ?? eventSchema.venue,
      addressRegion: 'Andalusia',
      addressCountry: 'ES',
    },
  },
  organizer: eventSchema.organizers.map(o => ({ '@type': 'Organization', name: o.name, url: o.url })),
  performer: eventSchema.performers.map(p => ({ '@type': 'MusicGroup', name: p.name, url: p.socialUrl })),
  offers: {
    '@type': 'Offer',
    url: eventSchema.ticketUrl,
    availability: 'https://schema.org/InStock',
  },
} : null;

const websiteLD = !eventSchema ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'InsanaSonido',
  url: siteUrl,
} : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="InsanaSonido" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Space+Grotesk:wght@400;700;900&display=swap" rel="stylesheet" />

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-M8XLQ99J8T"></script>
    <script is:inline src="/js/analytics.js"></script>



    {musicEventLD && (
      <script type="application/ld+json" set:html={JSON.stringify(musicEventLD).replace(/<\//g, '<\\/')} />
    )}
    {websiteLD && (
      <script type="application/ld+json" set:html={JSON.stringify(websiteLD).replace(/<\//g, '<\\/')} />
    )}
  </head>
  <body>
    <!-- Background Elements -->
    <div class="bg-gradient"></div>
    <div class="grid-overlay"></div>
    <div id="crt" aria-hidden="true"></div>

    <slot />

    <script src="/js/main.js" defer></script>
  </body>
</html>
