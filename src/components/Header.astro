---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../i18n/utils';

interface Props {
  variant: 'home' | 'event' | 'blog' | 'blog-post';
  logoMain?: string;
  logoAccent?: string;
  logoHref?: string;
}

const {
  variant,
  logoMain = 'Insana',
  logoAccent = 'Sonido',
  logoHref,
} = Astro.props;

const locale = Astro.currentLocale ?? 'es';
const t = useTranslations(locale);

const homeUrl = getRelativeLocaleUrl(locale, '/');
const blogUrl = getRelativeLocaleUrl(locale, '/blog/');
---
<header>
  <div class="container">
    <nav>
      {logoHref ? (
        <div class="logo">
          <a href={logoHref} style="text-decoration:none;color:inherit;">{logoMain}<span>{logoAccent}</span></a>
        </div>
      ) : (
        <div class="logo">{logoMain}<span>{logoAccent}</span></div>
      )}

      <div class="nav-links" id="navLinks">
        {variant === 'home' && (
          <>
            <a href="#events">{t('nav.events')}</a>
            <a href={blogUrl}>{t('nav.blog')}</a>
            <a href="https://www.instagram.com/projectinsana" target="_blank" rel="noopener noreferrer" class="text-magenta">{t('nav.instagram')}</a>
          </>
        )}
        {variant === 'event' && (
          <>
            <a href="#lineup">{t('nav.lineup')}</a>
            <a href="#info">{t('nav.info')}</a>
            <a href="#gallery">{t('nav.gallery')}</a>
            <a href="#tickets" class="text-magenta">{t('nav.tickets')}</a>
          </>
        )}
        {variant === 'blog' && (
          <>
            <a href={homeUrl}>{t('nav.home')}</a>
            <a href={`${homeUrl}#events`}>{t('nav.events')}</a>
          </>
        )}
        {variant === 'blog-post' && (
          <>
            <a href={homeUrl}>{t('nav.home')}</a>
            <a href={blogUrl}>{t('nav.blog')}</a>
          </>
        )}
      </div>

      <LanguageSwitcher />

      <button
        class="mobile-menu-btn"
        id="menuBtn"
        aria-expanded="false"
        aria-controls="navLinks"
        aria-label="Toggle navigation"
      >☰</button>
    </nav>
  </div>
</header>
